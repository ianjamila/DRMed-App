# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# supabase CLI local state
supabase/.temp/
supabase/.branches/

# claude code local state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# brainstorming companion mockups
.superpowers/

# playwright MCP temp dir
.playwright-mcp/

# ad-hoc screenshots
audit-*.png
verify-*.png
smoke-*.png

# firecrawl scrape cache
.firecrawl/

# graphify (knowledge graph build output, regenerated by post-commit hook)
graphify-out/
.gitattributes

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin

# Signature PNGs (forgeable artifacts — source of truth is the private
# `signatures` Supabase Storage bucket, populated via scripts/seed-signatures.ts)
scripts/seed/signatures/*.png
scripts/seed/signatures/*.jpg
scripts/seed/signatures/*.jpeg
.worktrees/

# import preflight reports (generated by scripts/import-legacy-customers.ts)
tmp/

backups/

# local consent UI-walkthrough artifacts
consent-0*.png
.playwright-mcp/
.env*.local
