# @vercel/speed-insights declares peerOptional deps for every framework it
# supports (@sveltejs/kit, etc.). npm's strict ERESOLVE tries to satisfy those
# optional peers and hits a phantom vite@7-vs-vite@8 conflict, even though
# SvelteKit is never installed. legacy-peer-deps relaxes that so installs
# resolve cleanly here and on Vercel. (Vercel's docs recommend this for its
# analytics/speed-insights packages.)
legacy-peer-deps=true
