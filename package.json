{
  "name": "drmed-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --linked > src/types/database.ts",
    "db:diff": "supabase db diff -f",
    "db:reset": "supabase db reset",
    "seed:test": "tsx --env-file=.env.local scripts/seed-test-users.ts",
    "seed:services": "tsx --env-file=.env.local scripts/seed-services.ts",
    "seed:closures": "tsx --env-file=.env.local scripts/seed-closures.ts",
    "import:tests": "tsx --env-file=.env.local scripts/import-test-list.ts",
    "import:descriptions": "tsx --env-file=.env.local scripts/populate-test-descriptions.ts",
    "seed:templates": "tsx --env-file=.env.local scripts/seed-result-templates.ts",
    "seed:hmo": "tsx --env-file=.env.local scripts/seed-hmo-providers.ts",
    "smoke:results": "tsx --env-file=.env.local scripts/smoke-render-results.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "supabase": "^2.95.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
