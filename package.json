{
  "name": "drmed-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "db:types:local": "supabase gen types typescript --local > src/types/database.ts",
    "db:types:remote": "test -n \"$SUPABASE_DB_URL\" || { echo 'SUPABASE_DB_URL not set — copy the Supabase project connection string into .env.local then re-run with: set -a; source .env.local; set +a; npm run db:types:remote'; exit 1; } && supabase gen types typescript --db-url \"$SUPABASE_DB_URL\" > src/types/database.ts",
    "db:diff": "supabase db diff -f",
    "db:reset": "supabase db reset",
    "seed:test": "tsx --env-file=.env.local scripts/seed-test-users.ts",
    "seed:services": "tsx --env-file=.env.local scripts/seed-services.ts",
    "seed:package-components": "tsx --env-file=.env.local scripts/seed-package-components.ts",
    "seed:closures": "tsx --env-file=.env.local scripts/seed-closures.ts",
    "import:tests": "tsx --env-file=.env.local scripts/import-test-list.ts",
    "import:descriptions": "tsx --env-file=.env.local scripts/populate-test-descriptions.ts",
    "seed:templates": "tsx --env-file=.env.local scripts/seed-result-templates.ts",
    "seed:hmo": "tsx --env-file=.env.local scripts/seed-hmo-providers.ts",
    "seed:physicians": "tsx --env-file=.env.local scripts/seed-physicians.ts",
    "seed:signatures": "tsx --env-file=.env.local scripts/seed-signatures.ts",
    "smoke:legacy-parsers": "tsx scripts/smoke-legacy-parsers.ts",
    "smoke:results": "tsx --env-file=.env.local scripts/smoke-render-results.ts",
    "smoke:chemistry": "tsx --env-file=.env.local scripts/smoke-chemistry-consolidated.ts",
    "wipe:operational": "tsx scripts/wipe-operational.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.51.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "exceljs": "^4.4.0",
    "jose": "^6.2.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.74.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/blob": "^2.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "supabase": "^2.100.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
