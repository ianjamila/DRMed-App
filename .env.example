# =============================================================================
# drmed.ph environment variables
# =============================================================================
# Copy this file to .env.local for local development.
# For Vercel deployments, set these in the Vercel project settings.
# NEVER commit .env.local or any file containing real values.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# From your Supabase project: Settings → API
# - URL is the project URL (https://<ref>.supabase.co)
# - Anon key is safe to expose to the browser
# - Service-role key bypasses RLS — server-only, NEVER expose to the browser

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# -----------------------------------------------------------------------------
# Patient session JWT
# -----------------------------------------------------------------------------
# Used to sign HttpOnly cookies for the patient portal session.
# Generate a strong random secret: `openssl rand -base64 48`
# Rotate quarterly. Rotation will invalidate active patient sessions.

PATIENT_SESSION_SECRET=replace-with-long-random-string
PATIENT_SESSION_TTL_MINUTES=30


# -----------------------------------------------------------------------------
# Site / app
# -----------------------------------------------------------------------------
# Used for absolute URLs in emails, OG tags, sitemap, etc.
# In Vercel, this should be https://drmed.ph for production.

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=drmed.ph


# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# https://resend.com — used for result-ready and appointment notifications.
# Verify the sending domain in Resend before going to production.

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=no-reply@drmed.ph
RESEND_REPLY_TO_EMAIL=info@drmed.ph


# -----------------------------------------------------------------------------
# SMS (Semaphore — Philippines)
# -----------------------------------------------------------------------------
# https://semaphore.co — local PH SMS provider with cheaper rates.
# Sender name must be pre-registered with Semaphore.

SEMAPHORE_API_KEY=your_semaphore_api_key
SEMAPHORE_SENDER_NAME=DRMED


# -----------------------------------------------------------------------------
# Google Sheets sync (accounting export)
# -----------------------------------------------------------------------------
# Service account credentials for the daily accounting sync to Google Sheets.
# 1. Create a service account in Google Cloud Console
# 2. Enable Google Sheets API
# 3. Download the JSON key
# 4. Paste the entire JSON object as a single line below (escape inner quotes)
# 5. Share your target Sheet with the service account email
#
# To set in Vercel: paste the raw JSON as the value (Vercel handles multi-line).

GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
ACCOUNTING_SHEET_ID=your-google-sheet-id-from-url

# Per-tab names inside the spreadsheet. Three tabs in one spreadsheet is
# preferred over three separate spreadsheets so one share grant covers
# everything. Names must match the tab labels exactly (case-sensitive).
ACCOUNTING_TAB_LAB=Lab Services
ACCOUNTING_TAB_CONSULT=Doctor Consultations
ACCOUNTING_TAB_PROCEDURE=Doctor Procedures HMO


# -----------------------------------------------------------------------------
# Cron secret
# -----------------------------------------------------------------------------
# Vercel automatically sets `Authorization: Bearer <CRON_SECRET>` on cron
# requests. Verify this header in cron route handlers to prevent abuse.
# Generate: `openssl rand -hex 32`

CRON_SECRET=replace-with-random-hex-string


# -----------------------------------------------------------------------------
# Error tracking (Sentry) — Phase 8
# -----------------------------------------------------------------------------
# Optional during early phases; required before production launch.

# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=


# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
# Vercel Analytics is enabled via the @vercel/analytics package and needs no
# env vars. If using Plausible or another self-hosted analytics, configure
# here.

# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=drmed.ph


# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Toggle features without code changes. Use 'true' or 'false' (lowercase).

FEATURE_ONLINE_BOOKING=false
FEATURE_PATHOLOGIST_SIGNOFF=false
FEATURE_STAFF_MFA_REQUIRED=false


# -----------------------------------------------------------------------------
# Local development overrides
# -----------------------------------------------------------------------------
# When using a local Supabase instance via `supabase start`, override the
# public URL and anon key with the local values printed by the CLI.
# Comment out the production values above when doing this.
